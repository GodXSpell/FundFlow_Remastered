{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "next.config.ts",
    "tailwind.config.ts"
  ],
  "exclude": ["src/**/*"]
}